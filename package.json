{
  "name": "electron-base-app",
  "version": "0.3.0",
  "description": "AutoIngest — Memory Card Importer",
  "main": "main/main.js",
  "scripts": {
    "start":     "electron .",
    "dist":      "electron-builder --mac --win",
    "dist:mac":  "electron-builder --mac",
    "dist:win":  "electron-builder --win",
    "build":     "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "dependencies": {
    "drivelist":        "^9.2.4",
    "electron-updater": "^6.3.9",
    "exifr":            "^7.1.3",
    "googleapis":       "^144.0.0",
    "sharp":            "^0.34.5"
  },
  "devDependencies": {
    "electron":         "^30.0.0",
    "electron-builder": "^26.8.1"
  },
  "author": "",
  "license": "MIT",
  "build": {
    "appId":       "com.autoingest.app",
    "productName": "AutoIngest",

    "publish": [
      {
        "provider": "github",
        "owner":    "murtazakhazanchi-ops",
        "repo":     "autoingest-releases",
        "private":  false
        "releaseType": "release"
      }
    ],

    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },

    "files": [
      "main/**/*",
      "renderer/**/*",
      "services/**/*",
      "config/**/*",
      "data/**/*",
      "assets/**/*",
      "package.json",
      "!**/node_modules/.cache/**",
      "!dist/**",
      "!**/*.md",
      "!**/.git/**"
    ],

    "mac": {
      "target":  [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "icon":    "assets/mac.icns",
      "category": "public.app-category.photography"
    },

    "dmg": {
      "title":   "${productName} ${version}",
      "window":  { "width": 540, "height": 380 }
    },

    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon":   "assets/win.ico"
    },

    "nsis": {
      "oneClick":           false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon":      "assets/win.ico",
      "uninstallerIcon":    "assets/win.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
