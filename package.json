{
  "name": "auto-ingest",
  "version": "0.9.3",
  "description": "AutoIngest — AJS Photo Archive Ingest System",
  "main": "main/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac --win",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "validate:metadata": "node scripts/validate-event-metadata.js",
    "realtime:install": "cd realtime-server && npm install",
    "realtime:start": "cd realtime-server && node server.js"
  },
  "dependencies": {
    "drivelist": "^9.2.4",
    "electron-updater": "^6.3.9",
    "exifr": "^7.1.3",
    "exiftool-vendored": "^28.8.0",
    "googleapis": "^144.0.0",
    "lucide": "^1.11.0",
    "sharp": "^0.34.5",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1"
  },
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.autoingest.app",
    "productName": "AutoIngest",
    "publish": [
      {
        "provider": "github",
        "owner": "murtazakhazanchi-ops",
        "repo": "autoingest-releases",
        "private": false,
        "releaseType": "release"
      }
    ],
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "extraResources": [
      {
        "from": "config/service-account-key.json",
        "to": "config/service-account-key.json"
      }
    ],
    "files": [
      "main/**/*",
      "renderer/**/*",
      "services/**/*",
      "config/**/*",
      "data/**/*",
      "assets/**/*",
      "package.json",
      "!**/node_modules/.cache/**",
      "!dist/**",
      "!**/*.md",
      "!**/.git/**"
    ],
    "asarUnpack": [
      "main/exiftool-config.pl"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/mac.icns",
      "category": "public.app-category.photography",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "${productName} ${version}",
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/win.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/win.ico",
      "uninstallerIcon": "assets/win.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
